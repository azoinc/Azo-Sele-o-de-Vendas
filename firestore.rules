rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }

    function getUserData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : null;
    }

    function getUserRole() {
      let data = getUserData();
      return (data != null) ? data.role : null;
    }

    function getUserImob() {
      let data = getUserData();
      return (data != null) ? data.imobiliariaId : null;
    }

    function isMaster() { return getUserRole() == 'master'; }
    function isAdmin() { return getUserRole() == 'admin' || isMaster(); }
    function isGestorImob() { return getUserRole() == 'gestor_imob'; }
    function isCorretor() { return getUserRole() == 'corretor'; }

    match /usuarios/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (isGestorImob() && existing().imobiliariaId == getUserImob())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (isGestorImob() && existing().imobiliariaId == getUserImob())
      );

      allow create: if isSignedIn() && isValidId(userId) && (
        (userId == request.auth.uid && incoming().role == 'corretor') ||
        isAdmin()
      );

      allow update: if isSignedIn() && isValidId(userId) && (
        isMaster() ||
        (isAdmin() && existing().role in ['corretor', 'gestor_imob'] && incoming().role in ['corretor', 'gestor_imob']) ||
        (request.auth.uid == userId && incoming().role == existing().role && incoming().imobiliariaId == existing().imobiliariaId)
      );

      allow delete: if isSignedIn() && isValidId(userId) && isMaster();
    }

    match /visitas/{visitaId} {
      allow get: if isSignedIn() && isValidId(visitaId) && (
        existing().corretorId == request.auth.uid || 
        isAdmin() || 
        (isGestorImob() && existing().imobiliariaId == getUserImob())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        isGestorImob() ||
        isCorretor()
      );

      allow create: if isSignedIn() && (
        incoming().corretorId == request.auth.uid
      );

      allow update: if isSignedIn() && isValidId(visitaId) && (
        existing().corretorId == request.auth.uid && 
        incoming().corretorId == existing().corretorId &&
        incoming().imobiliariaId == existing().imobiliariaId
      );

      allow delete: if isSignedIn() && isValidId(visitaId) && isMaster();
    }
  }
}
